{
  "annotations": { "list": [] },
  "editable": true,
  "title": "Model Performance",
  "uid": "model-performance",
  "panels": [
    {
      "title": "Fraud Recall",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "targets": [
        { "expr": "fraud_recall", "legendFormat": "recall" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.7, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          },
          "min": 0, "max": 1
        }
      }
    },
    {
      "title": "False Positive Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "false_positive_rate", "legendFormat": "FPR" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.15, "color": "yellow" },
              { "value": 0.2, "color": "red" }
            ]
          },
          "min": 0, "max": 1
        }
      }
    },
    {
      "title": "Prediction Confidence Distribution",
      "type": "histogram",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "prediction_confidence_bucket", "legendFormat": "{{le}}" }
      ]
    },
    {
      "title": "Fraud vs Legit Predictions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(fraud_predictions_total[5m])", "legendFormat": "fraud" },
        { "expr": "rate(legit_predictions_total[5m])", "legendFormat": "legit" }
      ]
    },
    {
      "title": "Total Predictions",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "prediction_request_total", "legendFormat": "{{status}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" }
}
