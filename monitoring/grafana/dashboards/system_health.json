{
  "annotations": { "list": [] },
  "editable": true,
  "title": "System Health",
  "uid": "system-health",
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(prediction_request_total[5m])",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "title": "Prediction Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ]
    },
    {
      "title": "Prediction Latency (p50)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 latency"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(prediction_request_total{status=\"error\"}[5m]) / rate(prediction_request_total[5m])",
          "legendFormat": "error rate"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" }
}
